%%{init: {"theme": "base", "themeVariables": {"background": "#ffffff", "primaryColor": "#ffffff", "primaryTextColor": "#000000", "primaryBorderColor": "#000000", "lineColor": "#000000", "secondaryColor": "#ffffff", "tertiaryColor": "#ffffff", "edgeLabelBackground": "#ffffff", "fontFamily": "Arial"}}}%%
flowchart TD
    A["OpenVINO Model Output"] --> B{"Check output shape"}

    B -->|"shape[1] = 6"| C["NMS output<br/>Existing pipeline"]
    C --> D["Select highest-confidence box"]
    D --> E["Read angle from class_id<br/>parse_angle_from_class_name()"]
    E --> F["Return<br/>(box, confidence, angle, confidence)"]

    B -->|"shape[1] > 6"| G["No-NMS output<br/>New pipeline"]
    G --> H["1. Confidence filter --conf<br/>Remove anchors below threshold"]
    H --> I["2. Top-K selection --topk<br/>Keep K highest-score anchors"]
    I --> J["3. Vector per anchor<br/>get_vector_from_scores()"]
    J --> K["Magnitude and angle<br/>from weighted class scores"]
    K --> L["4. IoU Greedy Grouping --iou<br/>Group overlapping anchors"]
    L --> M["Group bounding box<br/>magnitude-weighted average"]
    M --> N["5. Group vector sum<br/>Combine all anchor vectors"]
    N --> O["Final angle<br/>atan2(sum mag*sin, sum mag*cos)"]
    O --> P["Select highest-magnitude group"]
    P --> Q["Return<br/>(box, best_conf, angle, vector_magnitude)"]

    classDef normal fill:#ffffff,color:#000000,stroke:#000000,stroke-width:1.5px;
    class A,B,C,D,E,F,G,H,I,J,K,L,M,N,O,P,Q normal;